{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Windows VS2022 x64)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build_win",
      "cacheVariables": {
        "IDA_SDK_ROOT": "E:/CppTools/ida-sdk-main"
      }
    },
    {
      "name": "linux",
      "displayName": "Linux (Ninja)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "IDA_SDK_ROOT": "/mnt/e/CppTools/ida-sdk-main"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "configuration": "Release"
    },
    {
      "name": "linux",
      "configurePreset": "linux"
    }
  ]
}
